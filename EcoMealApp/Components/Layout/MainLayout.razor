@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            
            <div></div> 

            <div class="d-flex align-items-center gap-3">
                <AuthorizeView>
                    <Authorized Context="authContext">
                        <span class="text-success fw-bold d-flex align-items-center gap-1">
                            <span style="font-size: 0.75rem;">🟢</span> Connected
                        </span>

                        <span class="badge bg-primary text-white px-2 py-1">
                            @(authContext.User.FindFirst(ClaimTypes.Role)?.Value ?? "Unknown Role")
                        </span>

                        <span class="text-muted border-end pe-3">
                            Hi, <strong>@authContext.User.Identity?.Name</strong>
                        </span>

                        <form action="/api/auth/logout" method="post" class="m-0">
                            <AntiforgeryToken />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Log Out
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="nav-link" data-enhance="false">Login</a>
                    </NotAuthorized>
                </AuthorizeView>

                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" class="ms-2">About</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>