@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="page @(isSidebarCollapsed ? "collapsed" : "")">
    <div class="sidebar">
        <NavMenu IsCollapsed="isSidebarCollapsed" />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            
            <div>
                <button class="btn btn-link text-dark p-0 d-none d-sm-inline-block" @onclick="ToggleSidebar" title="Toggle Sidebar">
                    <i class="bi bi-list fs-4"></i>
                </button>
            </div> 

            <div class="d-flex align-items-center gap-3">
                <AuthorizeView>
                    <Authorized Context="authContext">
                        <span class="badge bg-primary text-white px-2 py-1">
                            @(authContext.User.FindFirst(ClaimTypes.Role)?.Value ?? "Unknown Role")
                        </span>

                        <span class="text-muted border-end pe-3">
                            Hi, <strong>@authContext.User.Identity?.Name</strong>
                        </span>

                        <form action="/api/auth/logout" method="post" class="m-0">
                            <AntiforgeryToken />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Log Out
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="nav-link" data-enhance="false">Login</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool isSidebarCollapsed = false;

    private void ToggleSidebar()
    {
        isSidebarCollapsed = !isSidebarCollapsed;
    }
}