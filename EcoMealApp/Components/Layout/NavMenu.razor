@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="nav-wrapper @(IsCollapsed ? "collapsed" : "")">
    <div class="top-row ps-3 navbar navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="">@(IsCollapsed ? "Eco" : "EcoMealApp")</a>
        </div>
    </div>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler"/>

    <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
        <nav class="nav flex-column">
            
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All" title="Home">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> 
                    <span class="nav-text">Home</span>
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="restaurants" title="Restaurants">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> 
                    <span class="nav-text">Restaurants</span>
                </NavLink>
            </div>
            
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="packages" title="Packages">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> 
                    <span class="nav-text">Packages</span>
                </NavLink>
            </div>
            
            <AuthorizeView>
                <Authorized>
                    @if (context.User.HasCustomRole("Admin"))
                    {
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="users" title="Users">
                                <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> 
                                <span class="nav-text">Users</span>
                            </NavLink>
                        </div>
        
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="orders" title="Orders">
                                <span class="bi bi-receipt-nav-menu" aria-hidden="true"></span> 
                                <span class="nav-text">Orders</span>
                            </NavLink>
                        </div>
                    }
    
                    @if (context.User.HasCustomRole("BusinessManager"))
                    {
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="manager/dashboard" title="Dashboard">
                                <span class="bi bi-speedometer2-nav-menu" aria-hidden="true"></span> 
                                <span class="nav-text">Dashboard</span>
                            </NavLink>
                        </div>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="manager/orders" title="Manage Orders">
                                <span class="bi bi-box-seam-nav-menu" aria-hidden="true"></span> 
                                <span class="nav-text">Manage Orders</span>
                            </NavLink>
                        </div>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="manager/packages" title="My Packages">
                                <span class="bi bi-grid-nav-menu" aria-hidden="true"></span> 
                                <span class="nav-text">My Packages</span>
                            </NavLink>
                        </div>
                    }
                </Authorized>
            </AuthorizeView>
        </nav>
    </div>
</div>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }
    
}