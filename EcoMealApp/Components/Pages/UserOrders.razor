@page "/my-orders"
@rendermode InteractiveServer
@attribute [Authorize]

@using EcoMealApp.Data.Entities
@using EcoMealApp.Services
@using EcoMealApp.Constants
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@inject IOrderService OrderService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>My Orders</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0">My Orders</h1>
            <p class="text-muted">Track your meal requests and their current status.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading orders...</span>
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger shadow-sm alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>Error:</strong> @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th style="width: 60px;" class="text-center">Details</th>
                        <th>Order Number</th>
                        <th>Restaurant / Store</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var o in orders)
                    {
                        <tr class="@(expandedOrderId == o.ID ? "table-active" : "")">
                            <td class="text-center">
                                <button class="btn btn-sm btn-light rounded-circle shadow-sm" type="button" @onclick="() => ToggleDetails(o.ID)">
                                    <i class="bi @(expandedOrderId == o.ID ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                </button>
                            </td>
                            <td class="fw-bold">Order #@o.OrderNumber</td>
                            <td>@(o.Business?.Name ?? "Unknown Business")</td>
                            
                            <td>
                                @if (o.Status?.Name == StatusConstants.Pending)
                                {
                                    <span class="badge bg-warning text-dark border">Pending</span>
                                }
                                else if (o.Status?.Name == StatusConstants.Accepted)
                                {
                                    <span class="badge bg-info text-dark border">In Kitchen</span>
                                }
                                else if (o.Status?.Name == StatusConstants.ReadyForPickup)
                                {
                                    <span class="badge bg-primary border">Ready for Pickup</span>
                                }
                                else if (o.Status?.Name == StatusConstants.Completed)
                                {
                                    <span class="badge bg-success border">Completed</span>
                                }
                                else if (o.Status?.Name == StatusConstants.Rejected || o.Status?.Name == "Cancelled")
                                {
                                    <span class="badge bg-danger border">Cancelled / Rejected</span>
                                }
                            </td>
                            
                            <td class="text-end">
                                @if (o.Status?.Name == StatusConstants.Pending)
                                {
                                    <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => OpenCancelPopup(o)">
                                        <i class="bi bi-x-circle"></i> Cancel Order
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small">No action available</span>
                                }
                            </td>
                        </tr>

                        @if (expandedOrderId == o.ID)
                        {
                            <tr class="bg-light">
                                <td colspan="5" class="p-4 border-bottom">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-header bg-white fw-bold">
                                            <i class="bi bi-basket me-2"></i> Order Contents
                                        </div>
                                        <div class="card-body p-0">
                                            @if (o.OrderPackages != null && o.OrderPackages.Any())
                                            {
                                                <ul class="list-group list-group-flush">
                                                    @foreach (var op in o.OrderPackages)
                                                    {
                                                        <li class="list-group-item d-flex justify-content-between align-items-center px-4 py-3">
                                                            <div>
                                                                <span class="badge bg-secondary me-3" style="font-size: 0.9rem;">@op.Quantity x</span>
                                                                <span class="fw-bold">@(op.Package?.Name ?? "Unknown Package")</span>
                                                            </div>
                                                            <span class="text-success fw-bold">
                                                                $@((op.Package?.Price * op.Quantity)?.ToString("0.00") ?? "0.00")
                                                            </span>
                                                        </li>
                                                    }
                                                </ul>
                                                <div class="card-footer bg-white text-end px-4 py-3">
                                                    <span class="text-muted me-3">Total:</span>
                                                    <span class="fs-5 fw-bold text-dark">
                                                        $@(o.OrderPackages.Sum(op => (op.Package?.Price ?? 0) * op.Quantity).ToString("0.00"))
                                                    </span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="p-4 text-center text-muted">
                                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                                    No package details found for this order.
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    @if (!orders.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">You haven't placed any orders yet.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (showCancelPopup && orderToCancel != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Cancel Order</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseCancelPopup" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to cancel <strong>Order #@orderToCancel.OrderNumber</strong> from <strong>@orderToCancel.Business?.Name</strong>?</p>
                    <p class="text-muted small mb-0">This cannot be undone.</p>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseCancelPopup">Keep Order</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmCancel">
                        <i class="bi bi-x-circle me-1"></i> Yes, Cancel Order
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Order> orders = new();
    private Order? orderToCancel;
    private Guid? expandedOrderId; 
    private bool showCancelPopup = false;
    private bool isLoading = true;
    private string? errorMessage;
    private Guid currentUserId;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrdersAsync();
    }

    private async Task LoadOrdersAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            
            // Getting the user ID from the claims (adjust standard ClaimTypes if you use a custom claim)
            var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value 
                           ?? authState.User.FindFirst("UserId")?.Value;

            if (!string.IsNullOrEmpty(userIdClaim) && Guid.TryParse(userIdClaim, out currentUserId))
            {
                orders = await OrderService.GetOrdersByUserIdAsync(currentUserId);
            }
            else
            {
                errorMessage = "Could not identify the logged-in user.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load your orders.";
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleDetails(Guid orderId)
    {
        if (expandedOrderId == orderId)
        {
            expandedOrderId = null; 
        }
        else
        {
            expandedOrderId = orderId; 
        }
    }

    private void OpenCancelPopup(Order order)
    {
        orderToCancel = order;
        showCancelPopup = true;
    }

    private void CloseCancelPopup()
    {
        orderToCancel = null;
        showCancelPopup = false;
    }

    private async Task ConfirmCancel()
    {
        if (orderToCancel == null) return;
        
        try
        {
            errorMessage = null;
            
            // As discussed, setting the status to "Rejected" (or "Cancelled") triggers your inventory restoration logic.
            // Using StatusConstants.Rejected or a literal string based on your exact status name.
            string targetStatus = "Rejected"; // Or StatusConstants.Rejected if it exists in your constants
            
            var success = await OrderService.UpdateOrderStatusByNameAsync(orderToCancel.ID, targetStatus);
            
            if (success)
            {
                // Update local UI state
                var targetOrder = orders.FirstOrDefault(o => o.ID == orderToCancel.ID);
                if (targetOrder != null)
                {
                    targetOrder.Status = new Status { Name = targetStatus };
                    StateHasChanged(); 
                }
            }
            else
            {
                 errorMessage = "Failed to cancel the order. It may have already been processed.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error occurred while canceling: {ex.Message}";
        }
        finally
        {
            CloseCancelPopup();
        }
    }
}