@page "/users"
@rendermode InteractiveServer
@attribute [Authorize]

@using EcoMealApp.Data.Entities
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>User Management</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Users</h1>
        
        <button class="btn btn-primary shadow-sm" @onclick="GoToAddPage">
            <i class="bi bi-person-plus-fill me-2"></i> Add New User
        </button>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th style="width: 50px;"></th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role ID</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var u in users)
                    {
                        <tr>
                            <td>
                                <div class="rounded-circle bg-light text-primary d-flex align-items-center justify-content-center shadow-sm" style="width: 35px; height: 35px;">
                                    <i class="bi bi-person-fill" style="font-size: 1.2rem;"></i>
                                </div>
                            </td>
                            <td class="fw-bold">@u.Name</td>
                            <td class="text-muted">@u.Email</td>
                            <td>
                                <span class="badge bg-light text-secondary border" style="font-family: monospace;">
                                    @u.RoleId
                                </span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-info me-2" @onclick="() => OpenViewModal(u)">
                                    <i class="bi bi-eye"></i> View
                                </button>
                                <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => GoToEditPage(u.ID)">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => OpenDeletePopup(u)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!users.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No users found.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (isViewModalOpen && selectedUser != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold">User Details</h5>
                    <button type="button" class="btn-close" @onclick="CloseViewModal"></button>
                </div>
                
                <div class="modal-body text-center p-0">
                    <div class="bg-light d-flex align-items-center justify-content-center w-100" style="height: 120px;">
                        <i class="bi bi-person-circle text-primary" style="font-size: 4rem;"></i>
                    </div>
                </div>

                <div class="modal-body">
                    <h4 class="fw-bold text-center mb-1">@selectedUser.Name</h4>
                    <p class="text-muted text-center mb-4">@selectedUser.Email</p>

                    <div class="mb-3 text-start">
                        <span class="text-muted small fw-bold text-uppercase border-bottom pb-1 d-block mb-2">System ID</span>
                        <span style="font-family: monospace;">@selectedUser.ID</span>
                    </div>

                    <div class="text-start">
                        <span class="text-muted small fw-bold text-uppercase border-bottom pb-1 d-block mb-2">Role ID</span>
                        <span style="font-family: monospace;">@selectedUser.RoleId</span>
                    </div>
                </div>
                
                <div class="modal-footer border-top-0 bg-light">
                    <button type="button" class="btn btn-secondary w-100" @onclick="CloseViewModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeletePopup && userToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-exclamation-circle text-danger mb-3" style="font-size: 3rem;"></i>
                    <h4 class="text-danger fw-bold mb-2">Delete User</h4>
                    <p class="text-muted mb-4">Are you sure you want to permanently delete <strong>@userToDelete.Name</strong>? This action cannot be undone.</p>
                    
                    <div class="d-flex justify-content-center gap-2">
                        <button class="btn btn-light w-50" @onclick="CancelDelete">Cancel</button>
                        <button class="btn btn-danger w-50" @onclick="ConfirmDelete">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<User> users = new();
    private User? userToDelete;
    private bool showDeletePopup = false;
    
    private bool isLoading = true;
    
    private bool isViewModalOpen = false;
    private User? selectedUser;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            isLoading = true;
            users = await Http.GetFromJsonAsync<List<User>>("api/user") ?? new List<User>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenViewModal(User usr)
    {
        selectedUser = usr;
        isViewModalOpen = true;
    }

    private void CloseViewModal()
    {
        isViewModalOpen = false;
        selectedUser = null;
    }

    private void GoToAddPage()
    {
        NavigationManager.NavigateTo("/users/create");
    }

    private void GoToEditPage(Guid id)
    {
        NavigationManager.NavigateTo($"/users/edit/{id}");
    }

    private void OpenDeletePopup(User usr)
    {
        userToDelete = usr;
        showDeletePopup = true;
    }

    private void CancelDelete()
    {
        userToDelete = null;
        showDeletePopup = false;
    }

    private async Task ConfirmDelete()
    {
        if (userToDelete == null) return;

        try
        {
            var response = await Http.DeleteAsync($"api/user/{userToDelete.ID}");

            if (response.IsSuccessStatusCode)
            {
                users.Remove(userToDelete);
            }
            else
            {
                Console.WriteLine($"Failed to delete user. Status Code: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting user: {ex.Message}");
        }
        finally
        {
            CancelDelete();
        }
    }
}