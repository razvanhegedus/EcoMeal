@page "/packages/create"
@rendermode InteractiveServer

@using EcoMealApp.Data.Entities
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Add New Package</PageTitle>

<h1>Add a New Package</h1>
<hr />

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" style="max-width: 600px;">@errorMessage</div>
}

<EditForm Model="newPackage" FormName="AddPackageForm" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="HandleInvalidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <div class="row" style="max-width: 600px;">
        <div class="col-md-6 form-group mb-3">
            <label for="name" class="form-label">Package Name</label>
            <InputText id="name" @bind-Value="newPackage.Name" class="form-control" />
        </div>

        <div class="col-md-6 form-group mb-3">
            <label for="business" class="form-label">Business</label>
            <InputSelect id="business" @bind-Value="newPackage.BusinessID" class="form-select">
                <option value="@Guid.Empty">-- Select Business --</option>
                @foreach (var business in businesses)
                {
                    <option value="@business.ID">@business.Name</option>
                }
            </InputSelect>
        </div>
    </div>

    <div class="form-group mb-3" style="max-width: 600px;">
        <label for="packageType" class="form-label">Package Type</label>
        <InputSelect id="packageType" @bind-Value="newPackage.PackageTypeID" class="form-select">
            <option value="@Guid.Empty">-- Select Package Type --</option>
            @foreach (var type in packageTypes)
            {
                <option value="@type.ID">@type.Name</option>
            }
        </InputSelect>
    </div>

    <div class="row" style="max-width: 600px;">
        <div class="col-md-6 form-group mb-3">
            <label for="price" class="form-label">Price</label>
            <InputNumber id="price" @bind-Value="newPackage.Price" class="form-control" />
        </div>

        <div class="col-md-6 form-group mb-3">
            <label for="quantity" class="form-label">Quantity</label>
            <InputNumber id="quantity" @bind-Value="newPackage.Quantity" class="form-control" />
        </div>
    </div>

    <div class="row" style="max-width: 600px;">
        <div class="col-md-6 form-group mb-3">
            <label for="pickupStart" class="form-label">Pickup Start Time</label>
            <InputDate id="pickupStart" Type="InputDateType.Time" @bind-Value="pickupStartTime" class="form-control" />
        </div>

        <div class="col-md-6 form-group mb-3">
            <label for="pickupEnd" class="form-label">Pickup End Time</label>
            <InputDate id="pickupEnd" Type="InputDateType.Time" @bind-Value="pickupEndTime" class="form-control" />
        </div>
    </div>

    <div class="form-group mb-3" style="max-width: 600px;">
        <label for="description" class="form-label">Description</label>
        <InputTextArea id="description" @bind-Value="newPackage.Description" class="form-control" rows="3" />
    </div>
    
    <div class="form-group mb-4" style="max-width: 600px;">
        <label class="form-label">Package Image</label>
        
        @if (!string.IsNullOrEmpty(newPackage.ImageURL))
        {
            <div class="mb-2">
                <img src="@newPackage.ImageURL" alt="Preview" style="max-width: 200px; height: auto; border-radius: 8px;" />
            </div>
        }
        
        <InputFile OnChange="HandleImageUpload" class="form-control" accept="image/*" />
    </div>
    
    <button type="submit" class="btn btn-success">Save Package</button>
    <button type="button" class="btn btn-secondary ms-2" @onclick="GoBack">Cancel</button>

</EditForm>

@code {
    private Package newPackage = new Package();
    
    // UI bindings for the time inputs, defaulted to 10:00 and 18:00
    private TimeOnly pickupStartTime = new TimeOnly(10, 0);
    private TimeOnly pickupEndTime = new TimeOnly(18, 0);
    
    private List<Business> businesses = new();
    private List<PackageType> packageTypes = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            businesses = await Http.GetFromJsonAsync<List<Business>>("api/business") ?? new List<Business>();
            packageTypes = await Http.GetFromJsonAsync<List<PackageType>>("api/packageType") ?? new List<PackageType>();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load initial data. Ensure APIs are running.";
            Console.WriteLine(ex.Message);
        }
    }

    private async Task HandleValidSubmit()
    {
        // Construct the final DateTime objects before saving
        newPackage.PickupStart = DateTime.Today.Add(pickupStartTime.ToTimeSpan());
        newPackage.PickupEnd = DateTime.Today.Add(pickupEndTime.ToTimeSpan());

        if (string.IsNullOrWhiteSpace(newPackage.Name))
        {
            errorMessage = "Please type a name."; 
            return;
        }
        
        if (newPackage.BusinessID == Guid.Empty)
        {
            errorMessage = "Please select a business.";
            return;
        }

        if (newPackage.PackageTypeID == Guid.Empty)
        {
            errorMessage = "Please select a package type.";
            return;
        }
        
        if (newPackage.Price <= 0)
        {
            errorMessage = "Price must be greater than zero.";
            return;
        }

        if (newPackage.Quantity <= 0)
        {
            errorMessage = "Quantity must be at least 1.";
            return;
        }

        if (newPackage.PickupEnd <= newPackage.PickupStart)
        {
            errorMessage = "Pickup End time must be after Pickup Start time.";
            return;
        }
        
        if (string.IsNullOrWhiteSpace(newPackage.Description))
        {
            errorMessage = "Please type a description."; 
            return;
        }

        errorMessage = null;
        newPackage.ID = Guid.NewGuid();
        
        var response = await Http.PostAsJsonAsync("api/package", newPackage);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/packages");
        }
        else
        {
            var errorDetails = await response.Content.ReadAsStringAsync();
            errorMessage = $"API Error: {errorDetails}";
        }
    }
    
    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        using var content = new MultipartFormDataContent();
        
        var fileStream = file.OpenReadStream(maxAllowedSize: 5120000);
        var streamContent = new StreamContent(fileStream);
        content.Add(streamContent, "file", file.Name);

        var response = await Http.PostAsync("api/package/upload-image", content);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<ImageUploadResponse>();
            if (result != null)
            {
                newPackage.ImageURL = result.Url;
            }
        }
        else
        {
            errorMessage = "Failed to upload the image.";
        }
    }

    public class ImageUploadResponse
    {
        public string Url { get; set; } = string.Empty;
    }

    private void HandleInvalidSubmit()
    {
        errorMessage = "Please fill out all required fields.";
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/packages");
    }
}