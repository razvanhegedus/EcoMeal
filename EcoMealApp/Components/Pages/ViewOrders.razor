@page "/orders"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@using EcoMealApp.Data.Entities
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http

<PageTitle>Order Management</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>All Orders</h1>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-light">
                    <tr>
                        <th style="width: 50px;"></th>
                        <th>Order #</th>
                        <th>Business</th>
                        <th>Customer</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var o in orders)
                    {
                        <tr>
                            <td>
                                <div class="rounded-circle bg-light text-success d-flex align-items-center justify-content-center shadow-sm" style="width: 35px; height: 35px;">
                                    <i class="bi bi-receipt" style="font-size: 1.2rem;"></i>
                                </div>
                            </td>
                            <td class="fw-bold">@o.OrderNumber</td>
                            
                            <td class="fw-medium">@(o.Business?.Name ?? "Unknown Business")</td>
                            <td>@(o.User?.Name ?? "Unknown User")</td>
                            
                            <td>
                                <span class="badge bg-primary">@(o.Status?.Name ?? "Pending")</span>
                            </td>
                            
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-info me-2" @onclick="() => OpenPackagesPopup(o)">
                                    <i class="bi bi-box-seam"></i> Packages
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => OpenDeletePopup(o)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!orders.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No orders found in the system.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* --- PACKAGES MODAL --- *@
@if (showPackagesPopup && orderToView != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom-0 bg-light">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-box-seam text-primary me-2"></i> 
                        Packages for Order #@orderToView.OrderNumber
                    </h5>
                    <button type="button" class="btn-close" @onclick="ClosePackagesPopup"></button>
                </div>
                <div class="modal-body p-4">
                    @if (orderToView.OrderPackages != null && orderToView.OrderPackages.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var package in orderToView.OrderPackages)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <div>
                                        <span class="fw-bold d-block">Package:</span>
                                        <span class="text-muted">@(package.Package?.Name ?? "Unknown Package")</span>
                                    </div>
                                    <span class="badge bg-success rounded-pill px-3 py-2">
                                        Qty: @package.Quantity
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center text-muted my-3">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            No packages found for this order.
                        </div>
                    }
                </div>
                <div class="modal-footer border-top-0">
                    <button class="btn btn-secondary" @onclick="ClosePackagesPopup">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@* --- DELETE MODAL --- *@
@if (showDeletePopup && orderToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-exclamation-circle text-danger mb-3" style="font-size: 3rem;"></i>
                    <h4 class="text-danger fw-bold mb-2">Delete Order</h4>
                    <p class="text-muted mb-4">Are you sure you want to permanently delete Order <strong>#@orderToDelete.OrderNumber</strong>? This action cannot be undone.</p>
                    
                    <div class="d-flex justify-content-center gap-2">
                        <button class="btn btn-light w-50" @onclick="CancelDelete">Cancel</button>
                        <button class="btn btn-danger w-50" @onclick="ConfirmDelete">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Order> orders = new();
    
    // Popup state management
    private Order? orderToDelete;
    private bool showDeletePopup = false;
    
    private Order? orderToView;
    private bool showPackagesPopup = false;
    
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        try
        {
            isLoading = true;
            // Because of the backend changes, this API call will now return the nested objects too!
            orders = await Http.GetFromJsonAsync<List<Order>>("api/order") ?? new List<Order>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading orders: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // --- Packages Popup Logic ---
    private void OpenPackagesPopup(Order order)
    {
        orderToView = order;
        showPackagesPopup = true;
    }

    private void ClosePackagesPopup()
    {
        orderToView = null;
        showPackagesPopup = false;
    }

    // --- Delete Popup Logic ---
    private void OpenDeletePopup(Order order)
    {
        orderToDelete = order;
        showDeletePopup = true;
    }

    private void CancelDelete()
    {
        orderToDelete = null;
        showDeletePopup = false;
    }

    private async Task ConfirmDelete()
    {
        if (orderToDelete == null) return;

        try
        {
            var response = await Http.DeleteAsync($"api/order/{orderToDelete.ID}");

            if (response.IsSuccessStatusCode)
            {
                orders.Remove(orderToDelete);
            }
            else
            {
                Console.WriteLine($"Failed to delete order. Status Code: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting order: {ex.Message}");
        }
        finally
        {
            CancelDelete();
        }
    }
}