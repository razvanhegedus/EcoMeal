@page "/order-success/{OrderId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using EcoMealApp.Data.Entities
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Order Placed Successfully</PageTitle>

<div class="container-fluid mt-4" style="max-width: 900px;">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Loading order details...</span>
            </div>
        </div>
    }
    else if (order == null)
    {
        <div class="alert alert-danger text-center shadow-sm">
            <i class="bi bi-exclamation-triangle-fill fs-3 d-block mb-2"></i>
            <h4>Order Not Found</h4>
            <p>We couldn't find the details for this order. It may have been canceled or removed.</p>
            <button class="btn btn-primary mt-3" @onclick="GoToRestaurants">Back to Restaurants</button>
        </div>
    }
    else
    {
        <div class="text-center mb-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
            <h1 class="mt-3 fw-bold text-dark">Order Confirmed!</h1>
            <p class="text-muted fs-5">Thank you for your order. Here are your details.</p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body d-flex justify-content-between align-items-center bg-light rounded">
                <div>
                    <h5 class="mb-1 text-primary"><i class="bi bi-shop me-2"></i> @(business?.Name ?? "Unknown Restaurant")</h5>
                    <p class="mb-0 text-muted small">Order ID: <span class="font-monospace">@order.ID</span></p>
                </div>
                <span class="badge bg-success fs-6 px-3 py-2">Status: Pending Pickup</span>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2">
                <h4 class="mb-0">Order Summary</h4>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px;" class="ps-4">Image</th>
                            <th>Package Name</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end pe-4">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var orderPackage in order.OrderPackages)
                        {
                            var pkg = packages.FirstOrDefault(p => p.ID == orderPackage.PackageID);
                            if (pkg != null)
                            {
                                <tr>
                                    <td class="ps-4">
                                        @if (!string.IsNullOrEmpty(pkg.ImageURL))
                                        {
                                            <img src="@pkg.ImageURL" alt="img" class="rounded shadow-sm" style="width: 45px; height: 45px; object-fit: cover;"/>
                                        }
                                        else
                                        {
                                            <div class="rounded bg-light text-secondary d-flex align-items-center justify-content-center shadow-sm" style="width: 45px; height: 45px;">
                                                <i class="bi bi-image" style="font-size: 1.2rem;"></i>
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-bold">
                                        @pkg.Name
                                        <div class="text-muted small fw-normal">
                                            <i class="bi bi-clock me-1"></i> Pickup: @pkg.PickupStart.ToString("HH:mm") - @pkg.PickupEnd.ToString("HH:mm")
                                        </div>
                                    </td>
                                    <td class="text-center fw-bold text-primary">
                                        x@(orderPackage.Quantity)
                                    </td>
                                    <td class="text-end text-muted">
                                        $@pkg.Price.ToString("0.00")
                                    </td>
                                    <td class="text-end fw-bold text-success pe-4">
                                        $@((pkg.Price * orderPackage.Quantity).ToString("0.00"))
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="4" class="text-end fw-bold fs-5 pt-3">Grand Total:</td>
                            <td class="text-end fw-bold text-success fs-5 pe-4 pt-3">
                                $@GetOrderTotal().ToString("0.00")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="d-flex justify-content-center mt-4 mb-5">
            <button class="btn btn-outline-primary btn-lg shadow-sm px-5" @onclick="GoToRestaurants">
                <i class="bi bi-arrow-left me-2"></i> Back to Restaurants
            </button>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid OrderId { get; set; }

    private Order? order;
    private Business? business;
    private List<Package> packages = new();
    
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Fetch the specific order by ID
            order = await Http.GetFromJsonAsync<Order>($"api/order/{OrderId}");

            if (order != null)
            {
                // 2. Fetch all packages to map the names, prices, and images
                packages = await Http.GetFromJsonAsync<List<Package>>("api/package") ?? new List<Package>();

                // 3. Fetch the business details for the header
                business = await Http.GetFromJsonAsync<Business>($"api/business/{order.BusinessID}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading order success details: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private double GetOrderTotal()
    {
        if (order?.OrderPackages == null || !packages.Any()) return 0;
        
        double total = 0;
        foreach (var op in order.OrderPackages)
        {
            var pkg = packages.FirstOrDefault(p => p.ID == op.PackageID);
            if (pkg != null)
            {
                total += pkg.Price * (double)op.Quantity;
            }
        }
        return total;
    }

    private void GoToRestaurants()
    {
        NavigationManager.NavigateTo("/restaurants");
    }
}