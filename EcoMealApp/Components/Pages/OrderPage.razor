@page "/order/{id:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using EcoMealApp.Data.Entities
@using EcoMealApp.Models.DTO
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

@if (selectedBusiness == null)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading business details...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid mt-4 mb-5" style="max-width: 1200px;">
        
        <div class="d-flex align-items-center mb-4 bg-white p-3 rounded shadow-sm border">
            <img src="@(string.IsNullOrEmpty(selectedBusiness.ImageURL) ? "default_restaurant.png" : selectedBusiness.ImageURL)" alt="@selectedBusiness.Name" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; margin-right: 20px;" />
            <div>
                <h2 class="mb-1 fw-bold text-dark">@selectedBusiness.Name</h2>
                <span class="badge bg-secondary fs-6">@selectedBusiness.BusinessType?.Name</span>
            </div>
            <div class="ms-auto">
                <button class="btn btn-outline-secondary" @onclick="CloseDetails">
                    <i class="bi bi-arrow-left me-1"></i> Back to Restaurants
                </button>
            </div>
        </div>
            
        <div class="row">
            <div class="col-lg-8 mb-4">
                <h4 class="mb-3">Available Packages</h4>
                    
                @if (isLoadingPackages)
                {
                    <p><em>Loading packages...</em></p>
                }
                else if (modalPackages != null && modalPackages.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var package in modalPackages) 
                        {
                            <div class="card shadow-sm border-0 bg-light">
                                <div class="card-body d-flex flex-column gap-3">
                                    <div>
                                        <h5 class="card-title fw-bold mb-1">@package.Name</h5>
                                        <p class="card-text text-muted small mb-0">@package.Description</p>
                                    </div>
                    
                                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-auto">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-success" style="font-size: 1.2rem; color: #3b824e !important;">$@package.Price.ToString("0.00")</span>
    
                                            @if (GetRemainingStock(package.ID) > 0)
                                            {
                                                <span class="text-muted" style="font-size: 0.85rem; margin-top: -2px;">
                                                    @GetRemainingStock(package.ID) available
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-danger fw-bold" style="font-size: 0.85rem; margin-top: -2px;">
                                                    Sold Out!
                                                </span>
                                            }
                                        </div>
                        
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="input-group" style="width: 120px;">
                                                <button class="btn btn-outline-secondary btn-sm px-3" type="button" 
                                                        @onclick="() => DecrementQuantity(package.ID)">-</button>
                
                                                <input type="text" class="form-control form-control-sm text-center fw-bold" 
                                                       value="@GetQuantity(package.ID)" readonly style="background-color: white;">
                
                                                <button class="btn btn-outline-secondary btn-sm px-3" type="button" 
                                                        @onclick="() => IncrementQuantity(package.ID)">+</button>
                                            </div>

                                            <button class="btn btn-primary btn-sm" @onclick="() => AddToOrder(package)">
                                                <i class="bi bi-cart-plus me-1"></i> Add
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info border-0 shadow-sm">
                        <i class="bi bi-info-circle me-2"></i> No packages currently available for this business.
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="card shadow border-primary sticky-top" style="top: 20px; z-index: 1000;">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-basket me-2"></i> Your Order</h5>
                    </div>
                    
                    <div class="card-body p-0">
                        @if (!runningCart.Any())
                        {
                            <div class="text-center p-5 text-muted">
                                <i class="bi bi-cart-x fs-1 d-block mb-3"></i>
                                <p class="mb-0">Your basket is empty.</p>
                                <small>Add some packages to get started!</small>
                            </div>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var cartItem in runningCart)
                                {
                                    var pkg = modalPackages?.FirstOrDefault(p => p.ID == cartItem.Key);
                                    if (pkg != null)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                            <div>
                                                <h6 class="mb-0 fw-bold">@pkg.Name</h6>
                                                <small class="text-muted">$@pkg.Price.ToString("0.00") each</small>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge bg-light text-dark border me-2">x @cartItem.Value</span>
                                                <span class="fw-bold text-success">$@((pkg.Price * cartItem.Value).ToString("0.00"))</span>
                                                
                                                <button class="btn btn-link text-danger p-0 ms-2" title="Remove" @onclick="() => RemoveFromCart(pkg.ID)">
                                                    <i class="bi bi-x-circle-fill"></i>
                                                </button>
                                            </div>
                                        </li>
                                    }
                                }
                            </ul>
                        }
                    </div>

                    @if (runningCart.Any())
                    {
                        <div class="card-footer bg-light border-top-0 pt-3 pb-4 px-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fs-5 fw-bold text-dark">Total:</span>
                                <span class="fs-4 fw-bold text-success">$@GetCartTotal().ToString("0.00")</span>
                            </div>
                            
                            <button class="btn btn-success w-100 py-2 fw-bold fs-5 shadow-sm mb-2" @onclick="FinishOrder" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Processing...</span>
                                }
                                else
                                {
                                    <i class="bi bi-credit-card me-2"></i> <span>Place Order</span>
                                }
                            </button>

                            <button class="btn btn-outline-danger w-100 py-2 fw-bold fs-6 shadow-sm" @onclick="CancelOrder" disabled="@isSubmitting">
                                <i class="bi bi-trash me-2"></i> <span>Cancel Order</span>
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div> 
}

@code 
{
    [Parameter]
    public Guid Id { get; set; }
    private Business? selectedBusiness; 
    private bool isLoadingPackages;
    private bool isSubmitting;

    private List<Package>? modalPackages;
    
    private Dictionary<Guid, int> packageQuantities = new();
    private Dictionary<Guid, int> runningCart = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            selectedBusiness = await Http.GetFromJsonAsync<Business>($"api/business/{Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching business: {ex.Message}");
            selectedBusiness = null;
        }

        if (selectedBusiness != null)
        {
            await ShowDetails(selectedBusiness);
        }
    }
    
    private async Task ShowDetails(Business business)
    {
        isLoadingPackages = true;
        modalPackages = null; 
        packageQuantities.Clear(); 
        runningCart.Clear();
        
        try 
        {
            modalPackages = await Http.GetFromJsonAsync<List<Package>>($"api/package/business/{business.ID}");
            
            if (modalPackages != null)
            {
                foreach (var package in modalPackages)
                {
                    packageQuantities[package.ID] = 1;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching packages: {ex.Message}");
            modalPackages = new List<Package>(); 
        }
        finally
        {
            isLoadingPackages = false;
        }
    }

    private int GetQuantity(Guid packageId)
    {
        return packageQuantities.TryGetValue(packageId, out var qty) ? qty : 1;
    }

    private int GetRemainingStock(Guid packageId)
    {
        var pkg = modalPackages?.FirstOrDefault(p => p.ID == packageId);
        if (pkg == null) return 0;
        
        int totalStock = pkg.Quantity; 
        int alreadyInCart = runningCart.TryGetValue(packageId, out var cartQty) ? cartQty : 0;
        
        return totalStock - alreadyInCart;
    }

    private void IncrementQuantity(Guid packageId)
    {
        int remainingStock = GetRemainingStock(packageId);

        if (packageQuantities.ContainsKey(packageId) && packageQuantities[packageId] < 99)
        {
            if (packageQuantities[packageId] < remainingStock)
            {
                packageQuantities[packageId]++;
            }
        }
    }

    private void DecrementQuantity(Guid packageId)
    {
        if (packageQuantities.ContainsKey(packageId) && packageQuantities[packageId] > 1) 
        {
            packageQuantities[packageId]--;
        }
    }

    private void AddToOrder(Package package)
    {
        int quantityToAdd = GetQuantity(package.ID);
        int remainingStock = GetRemainingStock(package.ID);
        
        if (quantityToAdd <= 0 || remainingStock <= 0) return;
        
        if (quantityToAdd > remainingStock)
        {
            quantityToAdd = remainingStock;
        }

        if (runningCart.ContainsKey(package.ID))
        {
            runningCart[package.ID] += quantityToAdd;
        }
        else
        {
            runningCart[package.ID] = quantityToAdd;
        }
        
        packageQuantities[package.ID] = 1;
    }

    private void RemoveFromCart(Guid packageId)
    {
        if (runningCart.ContainsKey(packageId))
        {
            runningCart.Remove(packageId);
        }
    }

    private void CancelOrder()
    {
        runningCart.Clear();

        if (modalPackages != null)
        {
            foreach (var package in modalPackages)
            {
                packageQuantities[package.ID] = 1;
            }
        }
    }

    private decimal GetCartTotal()
    {
        if (modalPackages == null || !runningCart.Any()) return 0;

        decimal total = 0;
        foreach (var item in runningCart)
        {
            var pkg = modalPackages.FirstOrDefault(p => p.ID == item.Key);
            if (pkg != null)
            {
                total += (decimal)pkg.Price * item.Value;
            }
        }
        return total;
    }

    private async Task FinishOrder()
    {
        if (!runningCart.Any()) return;

        isSubmitting = true;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userIdString = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);

            if (string.IsNullOrEmpty(userIdString) || !Guid.TryParse(userIdString, out Guid currentUserId))
            {
                Console.WriteLine("User is not logged in or invalid.");
                return;
            }

            var request = new CreateOrderRequest
            {
                BusinessId = selectedBusiness!.ID,
                UserId = currentUserId,
                Packages = runningCart.Select(kvp => new OrderPackageDto
                {
                    PackageId = kvp.Key,
                    Quantity = kvp.Value
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync("api/order", request);

            if (response.IsSuccessStatusCode)
            {
                var createdOrder = await response.Content.ReadFromJsonAsync<EcoMealApp.Data.Entities.Order>();
                if (createdOrder != null && createdOrder.ID != Guid.Empty)
                {
                    
                    Navigation.NavigateTo($"/order-success/{createdOrder.ID}");
                }
                else
                {
                    Navigation.NavigateTo("/restaurants");
                }
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Order error: {response.StatusCode} - {errorText}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception finishing order: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }
    
    private void CloseDetails()
    {
        selectedBusiness = null;
        modalPackages = null;
        Navigation.NavigateTo("/restaurants");
    }
}