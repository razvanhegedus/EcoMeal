@page "/order/{id:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using EcoMealApp.Data.Entities
@using Microsoft.AspNetCore.Authorization

@inject HttpClient Http
@inject NavigationManager Navigation

@if (selectedBusiness == null)
{
    <p><em>Loading business details...</em></p>
}
else
{
        
    <div id="light" class="white_content">
        <h2>@selectedBusiness.Name</h2>
        <p><strong>Category:</strong> @selectedBusiness.BusinessType?.Name</p>
        <img src="@(string.IsNullOrEmpty(selectedBusiness.ImageURL) ? "default_restaurant.png" : selectedBusiness.ImageURL)" alt="@selectedBusiness.Name" style="max-height: 150px; border-radius: 8px;" />
            
        <hr style="margin: 20px 0;" />
        <h4>Available Packages</h4>
            
        @if (isLoadingPackages)
        {
            <p><em>Loading packages...</em></p>
        }
        else if (modalPackages != null && modalPackages.Any())
        {
            <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px;">
                @foreach (var package in modalPackages) 
                {
                    <div style="border: 1px solid #eee; padding: 15px; border-radius: 8px; background-color: #f9f9f9; display: flex; flex-direction: column; gap: 15px;">
        
                        <div>
                            <h5 style="margin: 0;">@package.Name</h5>
                            <p style="margin: 5px 0 0 0; font-size: 0.9rem; color: #555;">@package.Description</p>
                        </div>
        
                        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
            
                            <span style="font-weight: bold; color: #28a745; font-size: 1.1rem;">$@package.Price</span>
            
                            <div style="display: flex; align-items: center; gap: 10px;">
                
                                <div class="input-group" style="width: 110px;">
                                    <button class="btn btn-outline-secondary btn-sm" type="button" 
                                            @onclick="() => DecrementQuantity(package.ID)">-</button>
    
                                    <input type="text" class="form-control form-control-sm text-center" 
                                           value="@GetQuantity(package.ID)" readonly style="background-color: white;">
    
                                    <button class="btn btn-outline-secondary btn-sm" type="button" 
                                            @onclick="() => IncrementQuantity(package.ID)">+</button>
                                </div>

                                <button class="btn btn-primary btn-sm" @onclick="() => AddToOrder(package)">Add to Order</button>
                                
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: #888; font-style: italic;">No packages currently available.</p>
        }
            
        <hr style="margin: 20px 0;" />

        <div style="display: flex; justify-content: flex-end;">
            <button class="btn btn-secondary" @onclick="CloseDetails">Close</button>
        </div>
    </div> 
}


@code 
{
    [Parameter]
    public Guid Id { get; set; }
    private Business? selectedBusiness; 
    private bool isLoadingPackages;
    private List<Package>? modalPackages;
    
    private Dictionary<Guid, int> packageQuantities = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            selectedBusiness = await Http.GetFromJsonAsync<Business>($"api/business/{Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching business: {ex.Message}");
            selectedBusiness = null;
        }

        if (selectedBusiness != null)
        {
            await ShowDetails(selectedBusiness);
        }
    }
    
    private async Task ShowDetails(Business business)
    {
        isLoadingPackages = true;
        modalPackages = null; 
        packageQuantities.Clear(); 
        
        try 
        {
            modalPackages = await Http.GetFromJsonAsync<List<Package>>($"api/package/business/{business.ID}");
            
            if (modalPackages != null)
            {
                foreach (var package in modalPackages)
                {
                    packageQuantities[package.ID] = 0;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching packages: {ex.Message}");
            modalPackages = new List<Package>(); 
        }
        finally
        {
            isLoadingPackages = false;
        }
    }


    private int GetQuantity(Guid packageId)
    {
        return packageQuantities.TryGetValue(packageId, out var qty) ? qty : 1;
    }

    private void IncrementQuantity(Guid packageId)
    {
        if (packageQuantities.ContainsKey(packageId))
        {
            if (packageQuantities[packageId] < 99) 
            {
                packageQuantities[packageId]++;
            }
        }
    }

    private void DecrementQuantity(Guid packageId)
    {
        if (packageQuantities.ContainsKey(packageId))
        {
            if (packageQuantities[packageId] > 0) 
            {
                packageQuantities[packageId]--;
            }
        }
    }

    private void AddToOrder(Package package)
    {
        int quantityToAdd = GetQuantity(package.ID);
        Console.WriteLine($"Added {quantityToAdd}x {package.Name} to the order!");
        
    }
    
    private void CloseDetails()
    {
        selectedBusiness = null;
        modalPackages = null;
        Navigation.NavigateTo("/restaurants");
    }
}