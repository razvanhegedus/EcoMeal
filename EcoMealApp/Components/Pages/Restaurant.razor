@page "/restaurants"
@rendermode InteractiveServer
@attribute [Authorize]

@using EcoMealApp.Data.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject HttpClient Http

<PageTitle>Restaurants</PageTitle>

<h1>Restaurants</h1>

@if (IsAdmin)
{
    <a href="/add-restaurant" class="btn btn-success mb-4" style="display: inline-block; padding: 10px 20px; background-color: #28a745; color: white; text-decoration: none; border-radius: 5px;">
        + Add New Restaurant
    </a>
}

@if (businesses == null)
{
    <p>
        <em>Loading...</em>
    </p>
}
else
{
    <div class="card__container" style="display: flex; gap: 1rem; flex-wrap: wrap;">
        @foreach (var restaurant in businesses)
        {
            <div class="card" style="width: 200px; height: 360px; border: 1px solid #ccc; padding: 10px; border-radius: 8px; display: flex; flex-direction: column;">
                
                <img src="@(string.IsNullOrEmpty(restaurant.ImageURL) ? "default_restaurant.png" : restaurant.ImageURL)" alt="@restaurant.Name" style="width:100%; height: 120px; object-fit: cover; border-radius: 4px;">
        
                <div class="container" style="text-align: center; margin-top: 10px; display: flex; flex-direction: column; flex-grow: 1;">
                    
                    <h4 style="font-size: 1.1rem; margin-bottom: 2px;"><b>@restaurant.Name</b></h4>
                    <p style="color: #666; font-size: 0.9rem;">@restaurant.BusinessType?.Name</p>
                    
                    <div class="d-flex flex-column gap-2 mt-3">
                        <a href="/order/@restaurant.ID" class="btn btn-primary w-100">
                            View Packages
                        </a>
                        
                        @* Using a fast C# variable instead of nested AuthorizeViews *@
                        @if (IsAdmin)
                        {
                            <a href="/edit-restaurant/@restaurant.ID" class="btn btn-secondary w-100">
                                Edit
                            </a>

                            <button class="btn btn-danger w-100" @onclick="() => OpenMainDeletePopup(restaurant)">
                                Delete
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (showMainDeletePopup && restaurantToDelete != null)
    {
        <div class="black_overlay" @onclick="CancelMainDelete"></div>
        
        <div class="small_modal">
            <h4 style="color: #dc3545; margin-top: 0;">Delete Restaurant</h4>
            <p>Are you sure you want to permanently delete <strong>@restaurantToDelete.Name</strong> and all of its associated packages?</p>
            <p style="font-size: 0.85rem; color: #666;">This action cannot be undone.</p>
            
            <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
                <button class="btn btn-secondary" @onclick="CancelMainDelete">Cancel</button>
                <button class="btn btn-danger" @onclick="ConfirmMainDelete">Yes, Delete</button>
            </div>
        </div>
    }
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool IsAdmin { get; set; } = false;
    private List<Business>? businesses;
    
    private Business? selectedBusiness; 
    private List<Package>? modalPackages;
    private bool isLoadingPackages = false;

    private Business? restaurantToDelete;
    private bool showMainDeletePopup = false;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var authState = await AuthState;
            var user = authState.User;

            IsAdmin = user.IsInRole("Admin");
        }

        // 2. Fetch API data
        businesses = await Http.GetFromJsonAsync<List<Business>>("api/business");
    }

    private async Task ShowDetails(Business business)
    {
        selectedBusiness = business;
        isLoadingPackages = true;
        modalPackages = null; 

        try 
        {
            modalPackages = await Http.GetFromJsonAsync<List<Package>>($"api/package/business/{business.ID}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching packages: {ex.Message}");
            modalPackages = new List<Package>(); 
        }
        finally
        {
            isLoadingPackages = false;
        }
    }

    private void CloseDetails()
    {
        selectedBusiness = null;
        modalPackages = null;
    }

    private void OpenMainDeletePopup(Business business)
    {
        restaurantToDelete = business;
        showMainDeletePopup = true;
    }

    private void CancelMainDelete()
    {
        restaurantToDelete = null;
        showMainDeletePopup = false;
    }

    private async Task ConfirmMainDelete()
    {
        if (restaurantToDelete == null) return;

        var response = await Http.DeleteAsync($"api/business/{restaurantToDelete.ID}");

        if (response.IsSuccessStatusCode)
        {
            businesses?.Remove(restaurantToDelete);
            CancelMainDelete();
        }
        else
        {
            Console.WriteLine("Failed to delete the restaurant.");
        }
    }
}