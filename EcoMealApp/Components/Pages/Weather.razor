@page "/weather"
@rendermode InteractiveServer

@using EcoMealApp.Data.Entities
@using EcoMealApp.Services
@inject HttpClient Http

<PageTitle>Restaurant</PageTitle>

<h1>Restaurant</h1>

<a href="/add-restaurant" class="btn btn-success mb-4" style="display: inline-block; padding: 10px 20px; background-color: #28a745; color: white; text-decoration: none; border-radius: 5px;">
    + Add New Restaurant
</a>


@if (businesses == null)
{
    <p>
        <em>Loading...</em>
    </p>
}
else
{
    <div class="card__container" style="display: flex; gap: 1rem; flex-wrap: wrap;">
        @foreach (var restaurant in businesses)
        {
            <div class="card" style="width: 200px; height: 250px; border: 1px solid #ccc; padding: 10px; border-radius: 8px;">
                <img src="@restaurant.ImageURL" alt="@restaurant.Name" style="width:100%; height: 120px; object-fit: cover;">
        
                <div class="container" style="text-align: center; margin-top: 10px;">
                    <h4><b>@restaurant.Name</b></h4>
                    <p>@restaurant.BusinessType.Name</p>
                    
                    <button class="btn btn-primary" @onclick="() => ShowDetails(restaurant)" style="margin-top: 5px;">View Details</button>
                </div>
            </div>
        }
    </div>
    
    @if (selectedBusiness != null)
    {
        <div id="fade" class="black_overlay" @onclick="CloseDetails"></div>
        
        <div id="light" class="white_content">
            <h2>@selectedBusiness.Name</h2>
            <p><strong>Category:</strong> @selectedBusiness.BusinessType.Name</p>
            <img src="@selectedBusiness.ImageURL" alt="@selectedBusiness.Name" style="max-height: 150px;" />
            
            <br /><br />
            <button class="btn btn-secondary" @onclick="CloseDetails">Close</button>
        </div>
    }
}


@code {
    private List<Business>? businesses;
    private Business? selectedBusiness; 

    protected override async Task OnInitializedAsync()
    {
        businesses = await Http.GetFromJsonAsync<List<Business>>("api/business");
    }

    private void ShowDetails(Business business)
    {
        selectedBusiness = business;
    }

    private void CloseDetails()
    {
        selectedBusiness = null;
    }
}